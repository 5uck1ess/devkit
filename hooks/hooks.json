{
  "description": "Safety hooks and RTK token optimization for Bash, Edit, and Write tools",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/safety-check.sh",
            "statusMessage": "Safety check...",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/rtk-rewrite.sh",
            "statusMessage": "RTK optimize...",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/safety-check.sh",
            "statusMessage": "Checking file safety...",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
