{
  "description": "devkit Codex enforcement stack. Requires [features].codex_hooks = true in an active Codex config layer.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" safety-check.sh",
            "statusMessage": "Safety check...",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" audit-trail.sh",
            "statusMessage": "Logging command...",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" pr-gate.sh",
            "statusMessage": "PR check...",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" safety-check.sh",
            "statusMessage": "Checking file safety...",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" security-patterns.sh",
            "statusMessage": "Security check...",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" devkit-guard.sh",
            "statusMessage": "Workflow guard...",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-permission-guard.sh\"",
            "statusMessage": "Checking approval request...",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" post-validate.sh",
            "statusMessage": "Validating output...",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" post-validate.sh",
            "statusMessage": "Validating write...",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" slop-detect.sh",
            "statusMessage": "Slop check...",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" lang-review.sh",
            "statusMessage": "Code quality check...",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" stop-gate.sh",
            "statusMessage": "Quality gate...",
            "timeout": 90
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/codex-hook.sh\" devkit-stop-guard.sh",
            "statusMessage": "Workflow check...",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
